{
  "name": "gpg-signing-service",
  "version": "1.0.1",
  "private": true,
  "description": "Git commit signing API, with GPG-compatible signatures",
  "license": "AGPL-3.0-only OR MIT",
  "type": "module",
  "imports": {
    "#gpg-signing-service": "./src/index.ts",
    "#*": "./src/*.ts",
    "#schemas": "./src/schemas/index.ts",
    "#types": "./src/types/index.ts"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "db:create": "wrangler d1 create gpg-signing-audit",
    "db:create:staging": "wrangler d1 create gpg-signing-audit-staging",
    "db:migrate": "wrangler d1 execute gpg-signing-audit --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute gpg-signing-audit --local --file=./migrations/0001_initial.sql",
    "db:migrate:staging": "wrangler d1 execute gpg-signing-audit-staging --env staging --file=./migrations/0001_initial.sql",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "dev": "wrangler dev",
    "dev:staging": "wrangler dev --env staging",
    "fmt": "dprint fmt",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "generate:api": "run -s generate:oapigen generate:oapi",
    "generate:oapi": "cd client && go tool oapi-codegen -config oapi-codegen.yaml openapi.json",
    "generate:oapigen": "bun scripts/generate-openapi.ts",
    "generate-key": "bash scripts/generate-key.sh",
    "prepare": "run typegen",
    "postinstall": "bunx lefthook install; bunx wrangler types >/dev/null",
    "kv:create": "wrangler kv namespace create JWKS_CACHE",
    "kv:create:staging": "wrangler kv namespace create JWKS_CACHE --env staging",
    "lint": "run -pk lint:eslint lint:biome",
    "lint:fix": "run -sK lint:eslint:fix lint:biome:fix",
    "lint:eslint": "eslint src/",
    "lint:eslint:fix": "eslint src/ --fix",
    "lint:biome": "biome check",
    "lint:biome:fix": "biome check --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "run @typescript/native --noEmit",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.4.0",
    "micro509": "0.11.0",
    "hono": "4.12.30",
    "openpgp": "6.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@tombi-toml/tombi": "1.2.0",
    "@types/bun": "1.3.14",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@typescript/native": "npm:typescript@^7",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/runner": "4.1.10",
    "@vitest/snapshot": "4.1.10",
    "dprint": "0.55.1",
    "eslint": "10.7.0",
    "jiti": "2.7.0",
    "jose": "6.2.3",
    "runner-run": "0.19.1",
    "typescript": ">=6,<7",
    "typescript-eslint": "8.63.0",
    "vitest": "^4.1.0",
    "wrangler": "4.110.0"
  },
  "packageManager": "bun@1.3.14"
}
